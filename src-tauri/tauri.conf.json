{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KDE Icon Helper",
  "version": "1.0.5",
  "identifier": "com.kahikara.kdeiconhelper",
  "build": {
    "beforeDevCommand": "GDK_BACKEND=x11 WINIT_UNIX_BACKEND=x11 vite dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "KDE Icon Helper",
        "width": 1180,
        "height": 760,
        "resizable": true,
        "minWidth": 980,
        "minHeight": 680,
        "decorations": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
